{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-notify"],
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": ["npx", "-y", "kubernetes-mcp-server@latest"],
    },
    "jcodemunch": {
      "type": "local",
      "command": ["uvx", "jcodemunch-mcp"],
    },
    "jdocmunch": {
      "type": "local",
      "command": ["uvx", "jdocmunch-mcp"],
    },
  },
}
