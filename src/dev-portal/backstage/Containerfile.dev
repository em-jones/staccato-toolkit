# Development Containerfile for Backstage
# Enables hot-reloading with yarn serve
# Usage: docker build -f Containerfile.dev -t backstage:dev .
#        docker run -it -v $(pwd):/workspace -p 7007:7007 -p 3000:3000 backstage:dev

FROM node:24-alpine
WORKDIR /workspace

# Install additional build tools for development
RUN apk add --no-cache git curl

# Copy package files
COPY package.json yarn.lock .yarnrc.yml ./
COPY .yarn ./.yarn

# Install dependencies
RUN yarn install

# Copy source code
COPY . .

# Expose both backend port (7007) and frontend dev server port (3000)
EXPOSE 7007 3000

# Run yarn serve for development with hot reload
CMD ["sleep", "10000"]
