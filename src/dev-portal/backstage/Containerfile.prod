# Production Containerfile for Backstage
# Multi-stage build for optimized runtime image
# Usage: docker build -f Containerfile.prod -t backstage:prod .

# Stage 1: Builder
FROM node:22-slim AS builder
WORKDIR /build

# Copy package files
COPY package.json yarn.lock .yarnrc.yml ./
COPY .yarn ./.yarn

# Install dependencies
RUN yarn install --immutable

# Copy source code
COPY . .

# Build all workspaces
RUN yarn build:all

# Stage 2: Runtime
FROM node:22-slim
WORKDIR /app

# Install dumb-init for proper signal handling
RUN apt-get update && apt-get install -y dumb-init && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 1000 backstage

# Copy built artifacts from builder
COPY --from=builder --chown=backstage:backstage /build/packages/backend/dist/bundle.tar.gz /tmp/
RUN cd /app && tar xzf /tmp/bundle.tar.gz && rm /tmp/bundle.tar.gz

# Copy node_modules from builder (optimized for production)
COPY --from=builder --chown=backstage:backstage /build/node_modules ./node_modules

# Switch to non-root user
USER backstage

# Expose backend port
EXPOSE 7007

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:7007/health', (res) => { if (res.statusCode !== 200) throw new Error(res.statusCode); })"

# Use dumb-init to properly handle signals
ENTRYPOINT ["dumb-init", "--"]

# Start backend server
CMD ["node", "dist/index.js"]
