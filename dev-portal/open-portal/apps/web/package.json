    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "nanoid": "catalog:",
    "nanostores": "^0.10.3",
    "nitro": "catalog:",
    "solid-js": "catalog:",
    "valibot": "catalog:",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@standard-community/standard-openapi": "catalog:",
    "@standard-schema/spec": "catalog:",
    "@tanstack/devtools-vite": "catalog:",
    "@types/bun": "latest",
    "@types/node": "^20.10.0",
    "drizzle-kit": "catalog:",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.3",
    "vite": "catalog:",
    "vite-plugin-solid": "catalog:"
