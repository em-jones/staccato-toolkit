{
  "name": "@openport/web",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vp dev --port 3000",
    "dev:openapi": "bun run scripts/generate-openapi.ts",
    "build": "bun run db:generate && tanstack-start build",
    "preview": "tanstack-start preview",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts"
  },
  "dependencies": {
    "@nanostores/solid": "^0.4.2",
    "@op-plugin/auth-core": "workspace:*",
    "@op-plugin/authentication-better-auth": "workspace:*",
    "@op-plugin/authorization-duck-iam": "workspace:*",
    "@op-plugin/catalog": "workspace:*",
    "@op-plugin/core-ui": "workspace:*",
    "@op-plugin/db-bun": "workspace:*",
    "@op-plugin/db-libsql": "workspace:*",
    "@op-plugin/events-s2": "workspace:*",
    "@op-plugin/nitro-server-plugin": "workspace:*",
    "@op-plugin/runtime-k8s": "workspace:*",
    "@op-plugin/solid-ui": "workspace:*",
    "@op-plugin/workflows-core": "workspace:*",
    "@op-plugin/workflows-hatchet": "workspace:*",
    "@op/tailwind-config": "workspace:*",
    "@op/platform": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@t3-oss/env-core": "^0.12.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.133.21",
    "@tanstack/solid-form": "catalog:",
    "@tanstack/solid-query": "catalog:",
    "@tanstack/solid-query-devtools": "catalog:",
    "@tanstack/solid-router": "catalog:",
    "@tanstack/solid-router-devtools": "catalog:",
